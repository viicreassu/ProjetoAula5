@model ProjetoMVC.Models.Aluno

@{
    ViewData["Title"] = "Cadastro de Aluno";
}

<h2>Cadastro de Aluno</h2>

@if (ViewBag.Mensagem != null)
{
    <div class="alert alert-success">
        @ViewBag.Mensagem
    </div>
}

<form asp-action="Cadastrar" method="post">

    <div>
        <label asp-for="Nome"></label>
        <input asp-for="Nome" class="form-control" />
        <span asp-validation-for="Nome" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="RA"></label>
        <input asp-for="RA" class="form-control" />
        <span asp-validation-for="RA" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Curso"></label>
        <input asp-for="Curso" class="form-control" />
        <span asp-validation-for="Curso" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="DataNascimento"></label>
        <input asp-for="DataNascimento" class="form-control" />
        <span asp-validation-for="DataNascimento" class="text-danger"></span>
    </div>

    <br />

    <button type="submit" class="btn btn-primary">
        Cadastrar
    </button>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
